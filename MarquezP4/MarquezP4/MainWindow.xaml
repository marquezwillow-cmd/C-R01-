<Window x:Class="MarquezP4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarquezP4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0,0,-118,-165">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="txtItemName" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="244,74,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="380"/>
        <Label Content="Item Name:" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="158,69,0,0" VerticalAlignment="Top" Width="116" Height="28"/>
        <Label Content=" Willow Marquez Inventory Command Pattern" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="188,30,0,0" VerticalAlignment="Top" Width="406" FontSize="18" FontWeight="Bold"/>
        <Button x:Name="btnAddOne" Content="Add One Item" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="174,131,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.437,0.528" Width="100" Click="btnAddOne_Click"/>
        <Button x:Name="btnUndo" Content="Undo" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="486,131,0,0" VerticalAlignment="Top" Width="115" Click="btnUndo_Click"/>
        <Button x:Name="btnAddMultiple" Content="Add Multiple (1-5)" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="319,131,0,0" VerticalAlignment="Top" Width="115" Click="btnAddMultiple_Click"/>
        <Label Content="Current Inventory:" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="158,188,0,0" VerticalAlignment="Top" Width="161"/>
        <ListBox x:Name="lstInventory" Grid.ColumnSpan="3" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="158,219,294,183"/>

    </Grid>
</Window>
