<Window x:Class="MarquezP5._0.SprocketForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Sprocket" Height="320" Width="380" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Item ID:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="txtItemId" Grid.Row="0" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <Label Content="Material:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <ComboBox x:Name="cmbMaterial" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center">
            <ComboBoxItem Content="Steel"/>
            <ComboBoxItem Content="Aluminum"/>
            <ComboBoxItem Content="Plastic"/>
        </ComboBox>

        <Label Content="Number of Teeth:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="txtTeeth" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <Label Content="Quantity:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
        <TextBox x:Name="txtQuantity" Grid.Row="3" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
            <Button Content="Submit" Width="80" Margin="0,0,10,0" Click="BtnSubmit_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>