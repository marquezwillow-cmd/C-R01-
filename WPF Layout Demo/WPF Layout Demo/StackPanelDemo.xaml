<Window x:Class="WPF_Layout_Demo.StackPanelDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StackPanelDemo" Height="300" Width="300">
    <StackPanel Orientation="Vertical" Margin="10">
        <Label>Label</Label>
        <TextBox>TextBox</TextBox>
        <CheckBox Margin="0,5">CheckBox</CheckBox>
        <CheckBox Margin="0,5">CheckBox</CheckBox>
        <ListBox Height="60">
            <ListBoxItem>ListBoxItem One</ListBoxItem>
            <ListBoxItem>ListBoxItem Two</ListBoxItem>
        </ListBox>
        <Button Margin="0,5">Button</Button>
    </StackPanel>
</Window>