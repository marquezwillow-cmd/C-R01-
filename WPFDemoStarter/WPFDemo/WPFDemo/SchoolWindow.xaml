<Window x:Class="WPFDemo.SchoolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School Management Platform" Height="380" Width="540" WindowStartupLocation="CenterScreen">    <Grid>
        <TabControl HorizontalAlignment="Left" Height="288" Margin="25,20,0,0" VerticalAlignment="Top" Width="475">
            <TabItem Header="Campuses">
                <Grid Background="#FFE5E5E5">
                    <ListBox Name="lbCampuses" HorizontalAlignment="Left" Height="240" VerticalAlignment="Top" Width="460" Margin="5"/>
                </Grid>
            </TabItem>
            <TabItem Header="Majors">
                <Grid Background="#FFE5E5E5">
                    <ListBox Name="lbMajors" HorizontalAlignment="Left" Height="240" VerticalAlignment="Top" Width="460" Margin="5"/>
                </Grid>
            </TabItem>
            <TabItem Header="Courses">
                <Grid Background="#FFE5E5E5">
                    <ListBox Name="lbCourses" HorizontalAlignment="Left" Height="240" VerticalAlignment="Top" Width="460" Margin="5"/>
                </Grid>
            </TabItem>
            <TabItem Header="Students">
                <Grid Background="#FFE5E5E5">
                    <ListBox Name="lbStudents" HorizontalAlignment="Left" Height="210" VerticalAlignment="Top" Width="463" Margin="2,2,2,0"/>
                    <Button Content="Add Student" HorizontalAlignment="Left" Margin="30,225,0,0" VerticalAlignment="Top" Width="185" Height="24" Click="Button_Click"/>
                    <Button Name="btnSave" Content="Save to File" HorizontalAlignment="Left" Margin="250,225,0,0" VerticalAlignment="Top" Width="185" Height="24" Click="Button_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>